# ─────────────────────────────────────────────────────────────
def metrics(y_true, y_pred, y_proba):
    nc   = y_proba.shape[1]
    acc  = accuracy_score(y_true, y_pred) * 100
    f1   = f1_score(y_true, y_pred, average='macro', zero_division=0) * 100
    prec = precision_score(y_true, y_pred, average='macro', zero_division=0) * 100
    rec  = recall_score(y_true, y_pred, average='macro', zero_division=0) * 100
    try:
        yb = label_binarize(y_true, classes=list(range(nc)))
        aucs = [auc(*roc_curve(yb[:, c], y_proba[:, c])[:2])
                for c in range(nc)
                if yb[:, c].sum() > 0 and y_proba[:, c].std() > 1e-6]
        mauc = np.mean(aucs) * 100 if aucs else 50.0
    except:
        mauc = 50.0
    return {'Acc': acc, 'F1': f1, 'Prec': prec, 'Rec': rec, 'AUC': mauc}



class UltraEnsemble:
    """
    3-level stacked generalization:
    Level 0: XGBoost × 3 variants + LightGBM × 3 + RF + ET + LSTM (per horizon)
    Level 1: Neural meta-learner on concatenated L0 probabilities
    Level 2: Calibrated logistic regression final combiner
    """

    def __init__(self, n_horizons=6, n_classes=3):
        self.n_horizons = n_horizons
        self.n_classes  = n_classes
        self.l0_models  = defaultdict(list)
        self.l1_models  = []
        self.l2_models  = []
        self.feature_names = None

    def _make_xgb(self, variant=0):
        configs = [
            # XGB-1: Deep trees, slow learning
            dict(n_estimators=1000, max_depth=9, learning_rate=0.01,
                 subsample=0.8, colsample_bytree=0.7, min_child_weight=1,
                 gamma=0.1, reg_alpha=0.05, reg_lambda=1.5,
                 tree_method='hist', random_state=SEED + variant, n_jobs=-1),
            # XGB-2: Shallow trees, fast
            dict(n_estimators=800, max_depth=5, learning_rate=0.03,
                 subsample=0.9, colsample_bytree=0.8, min_child_weight=3,
                 gamma=0.0, reg_alpha=0.1, reg_lambda=1.0,
                 tree_method='hist', random_state=SEED + variant + 1, n_jobs=-1),
            # XGB-3: Medium, different colsample
            dict(n_estimators=600, max_depth=7, learning_rate=0.02,
                 subsample=0.75, colsample_bytree=0.6, colsample_bylevel=0.8,
                 min_child_weight=2, gamma=0.05, reg_alpha=0.2, reg_lambda=2.0,
                 tree_method='hist', random_state=SEED + variant + 2, n_jobs=-1),
        ]
        return xgb.XGBClassifier(
            **configs[variant % 3],
            use_label_encoder=False, eval_metric='mlogloss'
        )

    def _make_lgb(self, variant=0):
        configs = [
            dict(n_estimators=1000, max_depth=8, learning_rate=0.01,
                 num_leaves=63, subsample=0.8, colsample_bytree=0.7,
                 min_child_samples=10, reg_alpha=0.1, reg_lambda=1.0,
                 random_state=SEED + variant),
            dict(n_estimators=800, max_depth=6, learning_rate=0.02,
                 num_leaves=31, subsample=0.9, colsample_bytree=0.8,
                 min_child_samples=5, reg_alpha=0.05, reg_lambda=0.5,
                 random_state=SEED + variant + 10),
            dict(n_estimators=600, max_depth=10, learning_rate=0.015,
                 num_leaves=127, subsample=0.75, colsample_bytree=0.65,
                 min_child_samples=15, reg_alpha=0.2, reg_lambda=2.0,
                 random_state=SEED + variant + 20),
        ]
        return lgb.LGBMClassifier(
            **configs[variant % 3],
            verbosity=-1, n_jobs=-1
        )

    def fit_level0(self, X_tr, Y_tr, X_va, Y_va):
        """Fit all Level-0 models."""
        print("  🔧 Fitting Level-0 models...")
        for hi in range(self.n_horizons):
            y_tr_h = Y_tr[:, hi]
            y_va_h = Y_va[:, hi]

            # 3× XGBoost variants
            for v in range(3):
                m = self._make_xgb(v)
                m.fit(X_tr, y_tr_h,
                      eval_set=[(X_va, y_va_h)],
                      verbose=False)
                self.l0_models[hi].append(('xgb', m))

            # 3× LightGBM variants
            for v in range(3):
                m = self._make_lgb(v)
                m.fit(X_tr, y_tr_h,
                      eval_set=[(X_va, y_va_h)],
                      callbacks=[lgb.early_stopping(50, verbose=False),
                                 lgb.log_evaluation(-1)])
                self.l0_models[hi].append(('lgb', m))

            # Random Forest
            rf = RandomForestClassifier(
                n_estimators=500, max_depth=None, max_features='sqrt',
                min_samples_leaf=2, random_state=SEED, n_jobs=-1, class_weight='balanced'
            )
            rf.fit(X_tr, y_tr_h)
            self.l0_models[hi].append(('rf', rf))

            # Extra Trees
            et = ExtraTreesClassifier(
                n_estimators=500, max_depth=None, max_features='sqrt',
                min_samples_leaf=2, random_state=SEED + 1, n_jobs=-1, class_weight='balanced'
            )
            et.fit(X_tr, y_tr_h)
            self.l0_models[hi].append(('et', et))

            print(f"    Horizon {HORIZONS[hi]:12s}: {len(self.l0_models[hi])} models fitted")

    def get_l0_probs(self, X):
        """Get concatenated probabilities from all Level-0 models."""
        all_probs = []
        for hi in range(self.n_horizons):
            h_probs = []
            for name, m in self.l0_models[hi]:
                p = m.predict_proba(X)
                h_probs.append(p)
            # Stack horizontally: [n_samples, n_models × n_classes]
            all_probs.append(np.hstack(h_probs))
        return all_probs  # List of [n_samples, n_models×3] per horizon

    def fit_level1(self, X_meta_tr, Y_tr, X_meta_va, Y_va):
        """Fit Level-1 neural meta-learner."""
        print("  🧠 Fitting Level-1 Neural Meta-Learner...")
        for hi in range(self.n_horizons):
            inp_dim = X_meta_tr[hi].shape[1]
            meta = NeuralMetaLearner(inp_dim, n_classes=self.n_classes).to(device)
            meta = train_meta_learner(
                meta,
                X_meta_tr[hi], Y_tr[:, hi],
                X_meta_va[hi], Y_va[:, hi],
                epochs=300, lr=1e-3
            )
            self.l1_models.append(meta)

    def get_l1_probs(self, X_meta, split='test'):
        """Get Level-1 probabilities."""
        probs = []
        for hi in range(self.n_horizons):
            meta = self.l1_models[hi]
            meta.eval()
            with torch.no_grad():
                xt = torch.tensor(X_meta[hi], dtype=torch.float32).to(device)
                p = F.softmax(meta(xt), dim=1).cpu().numpy()
            probs.append(p)
        return probs  # List of [n_samples, n_classes] per horizon

    def fit_level2(self, l0_probs_tr, l1_probs_tr, Y_tr, l0_probs_va, l1_probs_va, Y_va):
        """Fit Level-2 calibrated logistic regression."""
        print("  🎯 Fitting Level-2 Calibrated Combiner...")
        for hi in range(self.n_horizons):
            # Combine L0 + L1 probabilities
            X_l2_tr = np.hstack([l0_probs_tr[hi], l1_probs_tr[hi]])
            X_l2_va = np.hstack([l0_probs_va[hi], l1_probs_va[hi]])

            # Logistic regression with heavy regularization
            lr = LogisticRegression(
                C=0.5, max_iter=1000, multi_class='multinomial',
                solver='lbfgs', random_state=SEED, class_weight='balanced'
            )
            lr.fit(X_l2_tr, Y_tr[:, hi])
            self.l2_models.append(lr)

    def predict_ultra(self, X_l0, X_l1_meta):
        """Final ultra-fusion prediction."""
        l0_probs = self.get_l0_probs(X_l0)
        l1_probs = self.get_l1_probs(X_l1_meta)
        final_probs = []
        for hi in range(self.n_horizons):
            X_l2 = np.hstack([l0_probs[hi], l1_probs[hi]])
            p = self.l2_models[hi].predict_proba(X_l2)
            final_probs.append(p)
        return final_probs


class NeuralMetaLearner(nn.Module):
    """Compact neural meta-learner for stacked generalization."""
    def __init__(self, in_d, hidden=256, n_classes=3, dropout=0.4):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(in_d, hidden),
            nn.LayerNorm(hidden),
            nn.SiLU(),
            nn.Dropout(dropout),
            nn.Linear(hidden, hidden // 2),
            nn.LayerNorm(hidden // 2),
            nn.SiLU(),
            nn.Dropout(dropout * 0.5),
            nn.Linear(hidden // 2, hidden // 4),
            nn.SiLU(),
            nn.Linear(hidden // 4, n_classes)
        )

    def forward(self, x):
        return self.net(x)


def train_meta_learner(model, X_tr, y_tr, X_va, y_va, epochs=300, lr=1e-3):
    opt = optim.AdamW(model.parameters(), lr=lr, weight_decay=0.05)
    sch = CosineAnnealingWarmRestarts(opt, T_0=50, T_mult=2)

    xt = torch.tensor(X_tr, dtype=torch.float32).to(device)
    yt = torch.tensor(y_tr, dtype=torch.long).to(device)
    xv = torch.tensor(X_va, dtype=torch.float32).to(device)
    yv = torch.tensor(y_va, dtype=torch.long).to(device)

    # Class weights
    counts = np.bincount(y_tr, minlength=3).astype(float) + 1
    cw = torch.tensor(counts.sum() / (3 * counts), dtype=torch.float32).to(device)

    best_v, best_s, pat = float('inf'), None, 0
    for ep in range(epochs):
        model.train(); opt.zero_grad()
        loss = F.cross_entropy(model(xt), yt, weight=cw, label_smoothing=0.03)
        loss.backward()
        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
        opt.step(); sch.step()

        model.eval()
        with torch.no_grad():
            vl = F.cross_entropy(model(xv), yv).item()
        if vl < best_v:
            best_v = vl
            best_s = {k: v.cpu().clone() for k, v in model.state_dict().items()}
            pat = 0
        else:
            pat += 1
            if pat >= 30: break

    if best_s:
        model.load_state_dict(best_s)
    return model


# ─────────────────────────────────────────────────────────────
# 🏋️ BioSync Trainer (improved)
# ─────────────────────────────────────────────────────────────
def train_biosync(model, X_tr, Y_tr, X_va, Y_va,
                  epochs=200, patience=35, lr=3e-4, batch_size=64):
    """Train BioSync with mini-batches, mixed precision, heavy regularization."""
    scaler = GradScaler()
    opt = optim.AdamW(model.parameters(), lr=lr, weight_decay=0.05)
    total_steps = epochs
    sch = OneCycleLR(opt, max_lr=lr * 5, total_steps=total_steps, pct_start=0.15)

    # Class weights
    counts = np.bincount(Y_tr[:, 0], minlength=3).astype(float) + 1
    cw = torch.tensor(counts.sum() / (3 * counts), dtype=torch.float32).to(device)

    xv = torch.tensor(X_va, dtype=torch.float32).to(device)
    yv = torch.tensor(Y_va, dtype=torch.long).to(device)

    n = len(X_tr)
    train_losses, val_losses = [], []
    best_v, best_s, pat = float('inf'), None, 0

    for ep in range(1, epochs + 1):
        model.train()
        idx = np.random.permutation(n)
        ep_loss = 0.0
        n_batches = 0

        for start in range(0, n, batch_size):
            batch_idx = idx[start:start + batch_size]
            xt_b = torch.tensor(X_tr[batch_idx], dtype=torch.float32).to(device)
            yt_b = torch.tensor(Y_tr[batch_idx], dtype=torch.long).to(device)

            opt.zero_grad()
            with autocast():
                outs, _ = model(xt_b)
                # Weighted horizon loss: present > future
                loss = sum(
                    F.cross_entropy(outs[j], yt_b[:, j], weight=cw, label_smoothing=0.05)
                    * (1.0 - j * 0.05)
                    for j in range(N_HORIZONS)
                )

            scaler.scale(loss).backward()
            scaler.unscale_(opt)
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            scaler.step(opt)
            scaler.update()

            ep_loss += loss.item()
            n_batches += 1

        sch.step()
        train_losses.append(ep_loss / max(n_batches, 1))

        # Validation
        model.eval()
        with torch.no_grad():
            vo, _ = model(xv)
            vl = sum(F.cross_entropy(vo[j], yv[:, j]) for j in range(N_HORIZONS)).item()
        val_losses.append(vl)

        if vl < best_v:
            best_v = vl
            best_s = {k: v.cpu().clone() for k, v in model.state_dict().items()}
            pat = 0
        else:
            pat += 1
            if pat >= patience:
                print(f'    ⏹ Early stop at epoch {ep}')
                break

        if ep % 25 == 0:
            print(f'    Epoch {ep:03d} | Train={train_losses[-1]:.4f} | Val={vl:.4f}')

        if ep % 10 == 0 and torch.cuda.is_available():
            torch.cuda.empty_cache()

    if best_s:
        model.load_state_dict(best_s)
        del best_s
    return model, train_losses, val_losses



# 📁 Data Preparation (Enhanced Feature Engineering)
# ─────────────────────────────────────────────────────────────
def prepare_data(path, seq_len=10):
    global CLASS_NAMES
    tic('data')
    print("\n🧬 Phase 1: Loading & Engineering Features...")
    df = pd.read_csv(path)
    cols = df.columns.tolist()

    rid = next((c for c in cols if c.upper() == 'RID'), cols[0])
    dx  = next((c for c in cols if c in ('Diagnosis', 'DX_num', 'DX_label', 'DX')), None)
    if dx is None:
        dx = next((c for c in cols if 'diagn' in c.lower() or c.upper().startswith('DX')), None)
    if dx is None:
        raise ValueError("Diagnosis column not found. Columns: " + str(cols))
    print(f"  RID={rid} | DX={dx}")

    df[dx] = pd.to_numeric(df[dx], errors='coerce').fillna(0)
    raw = sorted(df[dx].unique())
    n_raw = len(raw)
    if   n_raw <= 3: dx_map = {v: i for i, v in enumerate(raw)}
    elif n_raw == 4: dx_map = {raw[0]: 0, raw[1]: 1, raw[2]: 1, raw[3]: 2}
    else:
        t = [raw[n_raw // 3], raw[2 * n_raw // 3]]
        dx_map = {v: (0 if v <= t[0] else 1 if v <= t[1] else 2) for v in raw}

    df['DX_label'] = df[dx].map(dx_map).astype(int)
    CLASS_NAMES = ['CN', 'MCI', 'AD']
    print(f"  Class dist: {df['DX_label'].value_counts().sort_index().to_dict()}")

    tcol = next((c for c in cols if any(t in c.lower() for t in ['year', 'age', 'time', 'visit'])), None)
    if tcol and tcol not in (rid, dx):
        df = df.sort_values([rid, tcol]).reset_index(drop=True)

    excl = {rid, dx, 'DX_label'}
    if tcol: excl.add(tcol)
    feats = [c for c in cols if c not in excl
             and df[c].dtype.kind in ('f', 'i')
             and df[c].std() > 1e-6]
    print(f"  Base features: {len(feats)}")

    df[feats] = df[feats].fillna(0)

    # ── Enhanced Feature Engineering ──
    # 1. Temporal velocity (1st diff)
    for f in feats[:]:
        df[f'vel_{f}'] = df.groupby(rid)[f].diff().fillna(0)

    # 2. Acceleration (2nd diff)
    for f in feats[:]:
        df[f'acc_{f}'] = df.groupby(rid)[f'vel_{f}'].diff().fillna(0)

    # 3. Rolling statistics (window=3)
    for f in feats[:]:
        df[f'roll_mean_{f}'] = df.groupby(rid)[f].transform(lambda x: x.rolling(3, min_periods=1).mean())
        df[f'roll_std_{f}']  = df.groupby(rid)[f].transform(lambda x: x.rolling(3, min_periods=1).std().fillna(0))

    vel_feats  = [f'vel_{f}'  for f in feats]
    acc_feats  = [f'acc_{f}'  for f in feats]
    rm_feats   = [f'roll_mean_{f}' for f in feats]
    rs_feats   = [f'roll_std_{f}'  for f in feats]
    all_feats  = feats + vel_feats + acc_feats + rm_feats + rs_feats
    print(f"  Total engineered features: {len(all_feats)}")

    # Scale
    df[all_feats] = RobustScaler().fit_transform(df[all_feats])

    # Build sequences
    rids   = df[rid].unique()
    X_list, Y_list = [], []
    for r in rids:
        p = df[df[rid] == r].reset_index(drop=True)
        n = len(p)
        if n < 2: continue
        for end in range(1, n):
            hist = p[all_feats].values[max(0, end - seq_len):end]
            if len(hist) < seq_len:
                hist = np.pad(hist, ((seq_len - len(hist), 0), (0, 0)), mode='edge')
            future = [int(p['DX_label'].iloc[min(end - 1 + s, n - 1)])
                      for s in range(N_HORIZONS)]
            X_list.append(hist.astype(np.float32))
            Y_list.append(future)

    X = np.array(X_list, dtype=np.float32)
    Y = np.array(Y_list, dtype=np.int32)
    Y = np.clip(Y, 0, 2)

    elapsed = toc('data')
    print(f"  ✅ Raw sequences: {len(X)} | Features: {X.shape[2]} | ⏱ {elapsed:.1f}s")

    # First split before augmentation (keep test set clean)
    X_trainval, X_te, Y_trainval, Y_te = train_test_split(
        X, Y, test_size=0.15, random_state=SEED, stratify=Y[:, 0]
    )

    print(f"\n  📊 Pre-augmentation: TrainVal={len(X_trainval)}, Test={len(X_te)}")

    # Augment only training data
    X_aug, Y_aug = generate_synthetic_data(
        X_trainval, Y_trainval,
        target_per_class=3000,
        seq_len=seq_len,
        n_feats=X.shape[2]
    )

    print(f"  📊 Post-augmentation: TrainVal={len(X_aug)}, Test={len(X_te)}")
    print(f"  Horizon distributions (augmented):")
    for i, h in enumerate(HORIZONS):
        vals, cnts = np.unique(Y_aug[:, i], return_counts=True)
        print(f"    {h}: { {CLASS_NAMES[v]: c for v, c in zip(vals, cnts)} }")

    return (X_aug, X_te, Y_aug, Y_te), all_feats



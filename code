class KANLayer(nn.Module):
    def __init__(self, in_f, out_f, dropout=0.0):
        super().__init__()
        self.linear = nn.Linear(in_f, out_f)
        self.sw     = nn.Parameter(torch.randn(out_f, in_f) * 0.02)
        self.norm   = nn.LayerNorm(out_f)
        self.drop   = nn.Dropout(dropout)
    def forward(self, x):
        out = self.norm(self.linear(x) + F.silu(x) @ self.sw.t())
        return self.drop(out)


class ResKAN(nn.Module):
    def __init__(self, d, p=0.3):
        super().__init__()
        self.k1   = KANLayer(d, d, p)
        self.k2   = KANLayer(d, d, p)
        self.norm = nn.LayerNorm(d)
    def forward(self, x):
        r = x
        x = F.silu(self.k1(x))
        x = self.k2(x)
        return self.norm(x + r)


class LightBioSync(nn.Module):
    """
    Redesigned BioSync: lighter, heavily regularized, focuses on generalization.
    Key insight: use fewer params, more dropout, stronger weight decay.
    """
    def __init__(self, in_d, h=128, heads=4, layers=3, n_hor=6, nc=3, dropout=0.4):
        super().__init__()
        # Input projection with heavy normalization
        self.proj = nn.Sequential(
            nn.Linear(in_d, h),
            nn.LayerNorm(h),
            nn.Dropout(dropout * 0.5),
            nn.SiLU()
        )

        # Lightweight LSTM (main temporal encoder)
        self.lstm = nn.LSTM(
            h, h // 2, num_layers=2,
            bidirectional=True, batch_first=True,
            dropout=dropout * 0.5
        )
        self.lstm_norm = nn.LayerNorm(h)

        # Compact Transformer (just 2 layers)
        enc = nn.TransformerEncoderLayer(
            h, heads, h * 2, dropout, batch_first=True, norm_first=True
        )
        self.trans = nn.TransformerEncoder(enc, num_layers=2)

        # Fusion gate (learn how much LSTM vs Transformer)
        self.gate = nn.Sequential(
            nn.Linear(h * 2, h),
            nn.Sigmoid()
        )
        self.fuse_norm = nn.LayerNorm(h)

        # Attention pooling
        self.attn_pool = nn.Sequential(
            nn.Linear(h, h // 4),
            nn.Tanh(),
            nn.Linear(h // 4, 1)
        )

        # KAN refinement (2 blocks only)
        self.kan_blocks = nn.ModuleList([ResKAN(h, dropout) for _ in range(2)])

        # Multi-horizon heads — shared backbone, separate heads
        self.shared_head = nn.Sequential(
            nn.Linear(h, h // 2),
            nn.LayerNorm(h // 2),
            nn.SiLU(),
            nn.Dropout(dropout)
        )
        self.horizon_heads = nn.ModuleList([
            nn.Linear(h // 2, nc) for _ in range(n_hor)
        ])

        self.h = h
        self.dropout_p = dropout

    def forward(self, x):
        B, T, _ = x.shape
        h = self.proj(x)

        # LSTM branch
        hl, _ = self.lstm(h)
        hl = self.lstm_norm(hl)

        # Transformer branch
        ht = self.trans(h)

        # Gated fusion
        combined = torch.cat([hl, ht], dim=-1)
        gate_w = self.gate(combined)
        fused = gate_w * hl + (1 - gate_w) * ht
        fused = self.fuse_norm(fused)

        # Attention pooling
        attn_w = torch.softmax(self.attn_pool(fused), dim=1)
        ctx = (attn_w * fused).sum(1)

        # KAN refinement
        for blk in self.kan_blocks:
            ctx = blk(ctx)

        # Shared head
        shared = self.shared_head(ctx)

        # Per-horizon predictions
        return [head(shared) for head in self.horizon_heads], ctx



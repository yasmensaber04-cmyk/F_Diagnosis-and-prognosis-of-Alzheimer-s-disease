class ConditionalGaussianCopula:
    """
    Generates synthetic patient sequences using Gaussian Copula model.
    Preserves correlations between features and temporal structure.
    """
    def __init__(self):
        self.class_stats = {}

    def fit(self, X_flat, y):
        """Fit per-class statistics on flattened sequences."""
        for c in range(3):
            mask = y == c
            if mask.sum() < 5:
                continue
            Xc = X_flat[mask]
            mu  = Xc.mean(0)
            cov = np.cov(Xc.T) + np.eye(Xc.shape[1]) * 1e-4
            self.class_stats[c] = {'mu': mu, 'cov': cov, 'n': mask.sum()}

    def generate(self, n_per_class=500, seq_len=10, n_feats=16):
        """Generate synthetic sequences per class."""
        X_syn, Y_syn = [], []
        for c, stats_ in self.class_stats.items():
            mu, cov = stats_['mu'], stats_['cov']
            # Cholesky decomp for fast sampling
            try:
                L = np.linalg.cholesky(cov)
                samples = mu + (np.random.randn(n_per_class, len(mu)) @ L.T)
            except np.linalg.LinAlgError:
                samples = np.random.multivariate_normal(mu, cov, n_per_class)

            # Reshape back to sequences (seq_len, n_feats)
            # Add temporal smoothing to make sequences realistic
            for i in range(n_per_class):
                flat = samples[i]
                seq = flat[:seq_len * n_feats].reshape(seq_len, n_feats)
                # Add small temporal noise for realism
                noise = np.random.randn(*seq.shape) * 0.02
                seq = seq + noise
                X_syn.append(seq.astype(np.float32))
                Y_syn.append(c)

        return np.array(X_syn, dtype=np.float32), np.array(Y_syn, dtype=np.int32)


class TimeSeriesAugmenter:
    """Advanced time-series augmentation techniques."""

    @staticmethod
    def jitter(X, sigma=0.03):
        return X + np.random.normal(0, sigma, X.shape).astype(np.float32)

    @staticmethod
    def scaling(X, sigma=0.1):
        scale = np.random.normal(1.0, sigma, (X.shape[0], 1, X.shape[2])).astype(np.float32)
        return X * scale

    @staticmethod
    def time_warp(X, sigma=0.2, knot=4):
        """Time warping augmentation."""
        from scipy.interpolate import CubicSpline
        orig_steps = np.arange(X.shape[1])
        result = np.zeros_like(X)
        for i in range(X.shape[0]):
            warp_steps = np.sort(np.random.choice(orig_steps[1:-1], knot, replace=False))
            warp_steps = np.concatenate([[orig_steps[0]], warp_steps, [orig_steps[-1]]])
            warp_vals = orig_steps + np.random.normal(0, sigma * X.shape[1], len(warp_steps))
            warp_vals[0] = 0; warp_vals[-1] = X.shape[1] - 1
            cs = CubicSpline(warp_steps, warp_vals)
            new_steps = np.clip(cs(orig_steps), 0, X.shape[1] - 1)
            for j in range(X.shape[2]):
                result[i, :, j] = np.interp(new_steps, orig_steps, X[i, :, j])
        return result.astype(np.float32)

    @staticmethod
    def window_slice(X, reduce_ratio=0.9):
        """Window slicing: take a random sub-window and resize."""
        target_len = int(X.shape[1] * reduce_ratio)
        start = np.random.randint(0, X.shape[1] - target_len + 1)
        sliced = X[:, start:start+target_len, :]
        # Resample back to original length
        result = np.zeros_like(X)
        for i in range(X.shape[0]):
            for j in range(X.shape[2]):
                result[i, :, j] = np.interp(
                    np.linspace(0, 1, X.shape[1]),
                    np.linspace(0, 1, target_len),
                    sliced[i, :, j]
                )
        return result.astype(np.float32)

    @staticmethod
    def mixup(X, Y, alpha=0.3):
        """Mixup augmentation for time series."""
        n = len(X)
        idx = np.random.permutation(n)
        lam = np.random.beta(alpha, alpha, n).astype(np.float32)
        lam_X = lam.reshape(n, 1, 1)
        X_mix = lam_X * X + (1 - lam_X) * X[idx]
        # For labels: take the dominant class
        Y_mix = np.where(lam > 0.5, Y, Y[idx])
        return X_mix.astype(np.float32), Y_mix.astype(np.int32)


def generate_synthetic_data(X_seq, Y_seq, target_per_class=2000, seq_len=10, n_feats=16):
    """
    Generate synthetic samples using multiple strategies:
    1. Gaussian Copula (structure-preserving)
    2. SMOTE-style nearest-neighbor interpolation
    3. Time-series augmentation
    """
    print("  🧬 Generating synthetic patient data...")

    # Strategy 1: Copula-based generation
    copula = ConditionalGaussianCopula()
    X_flat = X_seq.reshape(len(X_seq), -1)[:, :seq_len * n_feats]
    copula.fit(X_flat, Y_seq[:, 0])
    X_cop, Y_cop_flat = copula.generate(
        n_per_class=target_per_class // 3,
        seq_len=seq_len, n_feats=n_feats
    )
    Y_cop = np.column_stack([Y_cop_flat] * N_HORIZONS).astype(np.int32)

    # Strategy 2: SMOTE-style interpolation per class
    X_smote_list, Y_smote_list = [], []
    aug = TimeSeriesAugmenter()
    for c in range(3):
        mask = Y_seq[:, 0] == c
        Xc   = X_seq[mask]
        Yc   = Y_seq[mask]
        n_c  = len(Xc)
        n_needed = target_per_class // 3

        if n_c < 2:
            continue

        generated = []
        labels    = []
        while len(generated) < n_needed:
            i, j = np.random.choice(n_c, 2, replace=False)
            alpha_mix = np.random.uniform(0.2, 0.8)
            interp = (alpha_mix * Xc[i] + (1 - alpha_mix) * Xc[j]).astype(np.float32)
            interp += np.random.normal(0, 0.02, interp.shape).astype(np.float32)
            generated.append(interp)
            # Label: use closer sample's full horizon
            labels.append(Yc[i] if alpha_mix > 0.5 else Yc[j])

        X_smote_list.append(np.array(generated[:n_needed]))
        Y_smote_list.append(np.array(labels[:n_needed]))

    X_smote = np.vstack(X_smote_list).astype(np.float32)
    Y_smote = np.vstack(Y_smote_list).astype(np.int32)

    # Strategy 3: Time-series augmentation
    X_aug_parts = [
        aug.jitter(X_seq, 0.02),
        aug.jitter(X_seq, 0.05),
        aug.scaling(X_seq, 0.08),
        aug.scaling(X_seq, 0.15),
        aug.window_slice(X_seq, 0.85),
        aug.window_slice(X_seq, 0.9),
    ]
    X_aug = np.vstack(X_aug_parts).astype(np.float32)
    Y_aug = np.vstack([Y_seq] * len(X_aug_parts)).astype(np.int32)

    # Combine all
    X_all = np.vstack([X_seq, X_smote, X_aug, X_cop]).astype(np.float32)
    Y_all = np.vstack([Y_seq, Y_smote, Y_aug, Y_cop]).astype(np.int32)
    Y_all = np.clip(Y_all, 0, 2)

    print(f"  Original: {len(X_seq)} → Augmented: {len(X_all)} samples")
    print(f"    Copula: +{len(X_cop)} | SMOTE: +{len(X_smote)} | Aug: +{len(X_aug)}")

    # Balanced final resample
    pl = Y_all[:, 0]
    target = min(target_per_class, int(np.bincount(pl).max() * 1.1))
    Xb, Yb = [], []
    for cv in np.unique(pl):
        mask_ = pl == cv
        n_s = min(int(mask_.sum()), target)
        xr, yr = resample(X_all[mask_], Y_all[mask_], n_samples=n_s,
                          random_state=SEED, replace=False)
        Xb.append(xr); Yb.append(yr)

    X_bal = np.vstack(Xb).astype(np.float32)
    Y_bal = np.vstack(Yb).astype(np.int32)

    # Shuffle
    idx = np.random.permutation(len(X_bal))
    return X_bal[idx], Y_bal[idx]



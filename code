                fontweight='bold' if bold else 'normal', fontfamily='monospace')
    pdf.savefig(fig, bbox_inches='tight'); plt.close()


def page_timing(pdf):
    dark_style()
    fig, ax = plt.subplots(figsize=(11, 5))
    models = [k for k in TIMING if k not in ('data', 'pdf', 'total')]
    times  = [TIMING[k]['elapsed'] for k in models]
    bars   = ax.barh(models, times, color=[COLORS.get(k, '#888') for k in models], alpha=0.85)
    for bar, t in zip(bars, times):
        ax.text(bar.get_width() + 0.5, bar.get_y() + bar.get_height() / 2,
                f'{t:.1f}s', va='center', fontsize=10, color='#E6EDF3')
    ax.set_xlabel('Training Time (seconds)')
    ax.set_title('⏱  Training Time per Model', fontsize=14, color='#58A6FF')
    ax.grid(True, axis='x', alpha=0.3)
    plt.tight_layout(); pdf.savefig(fig); plt.close()


# ─────────────────────────────────────────────────────────────
# 🚀 Main Pipeline
# ─────────────────────────────────────────────────────────────
def run_pipeline(path):
    tic('total')
    print('\n' + '=' * 70)
    print('   BioSync KAN-Elite v4.0 — ULTRA ACCURACY Pipeline')
    print('   🎯 Target: Break 99% via 3-Level Stacked Generalization')
    print('=' * 70)

    # ── Data ──
    (X_aug, X_te, Y_aug, Y_te), feat_names = prepare_data(path)

    # Split augmented data into train/val
    X_train, X_val, Y_train, Y_val = train_test_split(
        X_aug, Y_aug, test_size=0.12, random_state=SEED, stratify=Y_aug[:, 0]
    )

    in_d = X_train.shape[2]
    seq_len = X_train.shape[1]
    print(f'\nDataset: Train={len(X_train)} Val={len(X_val)} Test={len(X_te)}')
    print(f'  Input dim={in_d}  seq={seq_len}  horizons={N_HORIZONS}')

    # Flatten for tree-based models
    Xf_train = X_train.reshape(len(X_train), -1)
    Xf_val   = X_val.reshape(len(X_val), -1)
    Xf_te    = X_te.reshape(len(X_te), -1)
    Xf_all   = X_aug.reshape(len(X_aug), -1)

    comp = {}

    # ══════════════════════════════════════════════════════════
    # MODEL 1 — LightBioSync (improved)
    # ══════════════════════════════════════════════════════════
    print('\n' + '─' * 60)
    print('⚡ Model 1: LightBioSync (Regularized)')
    tic('LightBioSync')

    biosync = LightBioSync(
        in_d=in_d, h=128, heads=4, layers=3,
        n_hor=N_HORIZONS, dropout=0.4
    ).to(device)

    print(f'  Parameters: {sum(p.numel() for p in biosync.parameters()):,}')

    biosync, train_l, val_l = train_biosync(
        biosync, X_train, Y_train, X_val, Y_val,
        epochs=200, patience=35, lr=3e-4, batch_size=64
    )

    biosync_res = []
    biosync.eval()
    with torch.no_grad():
        xt_all = torch.tensor(X_aug, dtype=torch.float32).to(device)
        xt_te  = torch.tensor(X_te,  dtype=torch.float32).to(device)
        out_all, emb_all = biosync(xt_all)
        out_te,  emb_te  = biosync(xt_te)

    emb_all_np = emb_all.cpu().numpy()
    emb_te_np  = emb_te.cpu().numpy()

    for hi in range(N_HORIZONS):
        p = F.softmax(out_te[hi], dim=1).cpu().numpy()
        m = metrics(Y_te[:, hi], np.argmax(p, 1), p)
        biosync_res.append(m)
        print(f'  {HORIZONS[hi]:12s} Acc={m["Acc"]:.1f}% F1={m["F1"]:.1f}% AUC={m["AUC"]:.1f}%')

    comp['LightBioSync'] = biosync_res
    print(f'  ⏱ LightBioSync done in {toc("LightBioSync"):.1f}s')

    if torch.cuda.is_available(): torch.cuda.empty_cache()
    gc.collect()

    # ══════════════════════════════════════════════════════════
    # MODEL 2 — Ultra Ensemble (3-level stacking)
    # ══════════════════════════════════════════════════════════
    print('\n' + '─' * 60)
    print('🔥 Model 2: Ultra Ensemble (3-Level Stacking)')
    tic('UltraFusion')

    ensemble = UltraEnsemble(n_horizons=N_HORIZONS, n_classes=3)

    # Level-0: Fit all base models
    ensemble.fit_level0(Xf_train, Y_train, Xf_val, Y_val)

    # Get L0 probs for meta-features
    print("  📊 Computing Level-0 meta-features...")
    l0_tr = ensemble.get_l0_probs(Xf_train)
    l0_va = ensemble.get_l0_probs(Xf_val)
    l0_te = ensemble.get_l0_probs(Xf_te)

    # Add BioSync embeddings as extra meta-features
    emb_train_split = emb_all_np[:len(X_train)]
    emb_val_split   = emb_all_np[len(X_train):]

    for hi in range(N_HORIZONS):
        # Append BioSync embedding probs to L0
        bs_p_tr = F.softmax(out_all[hi][:len(X_train)], dim=1).cpu().numpy()
        bs_p_va = F.softmax(out_all[hi][len(X_train):], dim=1).cpu().numpy()
        bs_p_te = F.softmax(out_te[hi], dim=1).cpu().numpy()

        l0_tr[hi] = np.hstack([l0_tr[hi], bs_p_tr, emb_train_split])
        l0_va[hi] = np.hstack([l0_va[hi], bs_p_va, emb_val_split])
        l0_te[hi] = np.hstack([l0_te[hi], bs_p_te, emb_te_np])

    # Level-1: Neural meta-learner
    ensemble.fit_level1(l0_tr, Y_train, l0_va, Y_val)

    # Get L1 probs
    l1_tr = ensemble.get_l1_probs(l0_tr)
    l1_va = ensemble.get_l1_probs(l0_va)
    l1_te = ensemble.get_l1_probs(l0_te)

    # Level-2: Calibrated combiner
    ensemble.fit_level2(l0_tr, l1_tr, Y_train, l0_va, l1_va, Y_val)

    # Final prediction
    print("  🎯 Computing final Ultra-Fusion predictions...")
    ultra_res = []
    final_probs_all = []

    for hi in range(N_HORIZONS):
        X_l2_te = np.hstack([l0_te[hi], l1_te[hi]])
        fp = ensemble.l2_models[hi].predict_proba(X_l2_te)
        m = metrics(Y_te[:, hi], np.argmax(fp, 1), fp)
        ultra_res.append(m)
        final_probs_all.append(fp)
        print(f'  {HORIZONS[hi]:12s} Acc={m["Acc"]:.1f}% F1={m["F1"]:.1f}% AUC={m["AUC"]:.1f}%')

    comp['UltraFusion'] = ultra_res
    print(f'  ⏱ UltraFusion done in {toc("UltraFusion"):.1f}s')

    # ══════════════════════════════════════════════════════════
    # Print summary
    # ══════════════════════════════════════════════════════════
    print('\n' + '=' * 70)
    print(f"{'Model':22s} | {'Avg Acc':>8} | {'Avg F1':>7} | {'Avg AUC':>8}")
    print('-' * 60)
    for mod in comp:
        aa = np.mean([comp[mod][h]['Acc'] for h in range(N_HORIZONS)])
        af = np.mean([comp[mod][h]['F1']  for h in range(N_HORIZONS)])
        au = np.mean([comp[mod][h]['AUC'] for h in range(N_HORIZONS)])
        s  = '🏆 ' if 'Ultra' in mod else '  '
        print(f'{s}{mod:20s} | {aa:7.1f}% | {af:6.1f}% | {au:7.1f}%')
    print('=' * 70)

    # Check if we hit 99
    best_acc = max(comp['UltraFusion'][h]['Acc'] for h in range(N_HORIZONS))
    avg_acc  = np.mean([comp['UltraFusion'][h]['Acc'] for h in range(N_HORIZONS)])
    print(f'\n🎯 Best horizon acc: {best_acc:.1f}%')
    print(f'🎯 Avg fusion acc:   {avg_acc:.1f}%')
    if avg_acc >= 99:
        print('🏆🏆🏆 ACHIEVED 99%+ AVERAGE ACCURACY! 🏆🏆🏆')
    elif best_acc >= 99:
        print('🏆 Achieved 99%+ on at least one horizon!')

    # ══════════════════════════════════════════════════════════
    # PDF Report
    # ══════════════════════════════════════════════════════════
    tic('pdf')
    print('\n📄 Generating PDF Report...')
    dark_style()

    with PdfPages('BioSync_KAN_Elite_v4_ULTRA_Report.pdf') as pdf:
        page_cover(pdf)
        page_timing(pdf)
        page_learning(train_l, val_l, pdf)
        page_comparison_bars(comp, pdf)
        page_trend(comp, pdf)
        page_heatmap(comp, pdf)

        for hi, hor in enumerate(HORIZONS):
            fp = final_probs_all[hi]
            page_conf_matrix(Y_te[:, hi], np.argmax(fp, 1),
                             f'UltraFusion — {hor}', pdf, COLORS['UltraFusion'])
            page_roc(Y_te[:, hi], fp, f'UltraFusion ROC — {hor}', pdf)

        page_summary(comp, pdf)
        page_final_summary(comp, pdf)

    toc('pdf'); toc('total')
    print(f'\n✅ PDF saved: BioSync_KAN_Elite_v4_ULTRA_Report.pdf')
    print(f'⏱ Total time: {TIMING["total"]["elapsed"]:.1f}s')

    if torch.cuda.is_available(): torch.cuda.empty_cache()
    gc.collect()

    return comp


